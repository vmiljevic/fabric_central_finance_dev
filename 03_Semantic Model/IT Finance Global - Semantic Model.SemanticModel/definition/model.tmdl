model Model
	culture: en-US
	collation: Latin1_General_100_BIN2_UTF8
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["DatabaseQuery"]

annotation PBI_ProTooling = ["RemoteModeling","WebModelingEdit"]

annotation __TEdtr = 1

ref table _measures
ref table dim_date
ref table dim_company
ref table dim_profit_centers
ref table dim_cost_elements
ref table fact_costs_cbn
ref table Type

